---
import RetroGrid from "./RetroGrid.astro";

interface Props {
  title?: string;
  subtitle?: {
    regular: string;
    gradient: string;
  };
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  bottomImage?: {
    light: string;
    dark: string;
  };
}

const {
  title = "Qably",
  subtitle = {
    regular: "El gestor de QA creado para",
    gradient: "Ingenieros de Software",
  },
  description = "Elimina la carga de documentar pruebas. Qably analiza tus archivos de test (Playwright, Jest, Vitest), genera casos estructurados con IA y mantiene tu documentación sincronizada automáticamente con cada Git Push.",
  ctaText = "Comenzar gratis",
  ctaHref = "/register",
  bottomImage = {
    light: "/images/dashboard-mockup-dark.png", // Dark first, so we'll use dark for both or a premium image
    dark: "/images/dashboard-mockup-dark.png",
  },
} = Astro.props;

const webUrl = import.meta.env.PUBLIC_WEB_URL || "http://localhost:3000";
const registerUrl = `${webUrl}${ctaHref}`;
---

<section class="relative flex min-h-[90vh] flex-col items-center justify-center overflow-hidden border-b border-border/40 py-20 lg:py-32">
  <!-- Retro Grid Background -->
  <RetroGrid angle={60} cellSize={50} opacity={0.35} />

  <!-- Hero Content -->
  <div class="relative z-10 mx-auto max-w-5xl px-4 text-center sm:px-6 lg:px-8">
    <!-- Eyebrow Pill -->
    <div class="mx-auto mb-6 flex max-w-fit items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-3 py-1 text-xs font-semibold text-primary backdrop-blur-md animate-fade-in-up">
      <span>✨ Generación automática de QA con Claude Sonnet 3.5</span>
    </div>

    <!-- Main Headings -->
    <h1 class="animate-fade-in-up font-sans text-4xl font-extrabold tracking-tight text-fg sm:text-5xl md:text-6xl lg:text-7xl">
      <span class="block text-fg-muted font-light leading-tight">{subtitle.regular}</span>
      <span class="mt-2 block bg-gradient-to-r from-primary via-ai to-primary bg-clip-text text-transparent bg-[size:200%] animate-[shimmer_8s_ease_infinite] leading-none">
        {subtitle.gradient}
      </span>
    </h1>

    <!-- Description -->
    <p class="mx-auto mt-6 max-w-2xl text-base text-fg-muted sm:text-lg md:text-xl reveal visible">
      {description}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row reveal visible">
      <a
        href={registerUrl}
        class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-primary px-8 text-base font-semibold text-primary-fg shadow-lg shadow-primary/20 transition-all hover:bg-primary-hover hover:scale-[1.02] sm:w-auto"
      >
        {ctaText} →
      </a>
      <a
        href="#solution"
        class="inline-flex h-12 w-full items-center justify-center rounded-lg border border-border bg-bg-elevated/40 px-8 text-base font-semibold text-fg transition-all hover:bg-bg-hover hover:border-border-strong sm:w-auto backdrop-blur-sm"
      >
        Ver cómo funciona
      </a>
    </div>

    <!-- Mockup Container -->
    <div class="relative mt-16 sm:mt-24 reveal visible">
      <div class="group relative rounded-xl border border-border-strong bg-bg-subtle/80 p-2 shadow-2xl shadow-black/80 backdrop-blur-md">
        <!-- Window Chrome controls -->
        <div class="flex items-center gap-1.5 border-b border-border/60 pb-3 px-2">
          <div class="h-3 w-3 rounded-full bg-red-500/80"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500/80"></div>
          <div class="h-3 w-3 rounded-full bg-green-500/80"></div>
          <span class="ml-4 text-[10px] font-mono text-fg-subtle">qably.app/projects/qably/ai-review</span>
        </div>
        
        <div class="overflow-hidden rounded-lg bg-bg aspect-[16/9] relative flex items-center justify-center border border-border/40">
          <!-- Visual representation of the dashboard in pure HTML/CSS to make it load instantly and look incredible -->
          <div class="absolute inset-0 grid grid-cols-[220px_1fr] text-left text-xs font-sans">
            <!-- Mock Sidebar -->
            <div class="border-r border-border/60 bg-bg-elevated p-4 flex flex-col gap-6">
              <div class="font-bold text-sm tracking-tight text-fg flex items-center gap-1.5">
                <div class="h-4 w-4 bg-primary rounded flex items-center justify-center text-[10px] text-white">Q</div>
                Qably
              </div>
              <div class="flex flex-col gap-2">
                <div class="text-[10px] font-semibold text-fg-subtle uppercase tracking-wider">Dashboard</div>
                <div class="h-7 rounded bg-bg-hover/80 px-2 flex items-center text-fg font-medium">📋 Suites</div>
                <div class="h-7 rounded px-2 flex items-center text-fg-muted">⏱ Runs</div>
                <div class="h-7 rounded px-2 flex items-center text-fg-muted">🚀 Pipelines</div>
                <div class="h-7 rounded bg-primary/10 px-2 flex items-center text-primary font-medium gap-1.5">
                  ✨ AI Review
                  <span class="h-2 w-2 rounded-full bg-primary animate-ping"></span>
                </div>
              </div>
            </div>

            <!-- Mock Workspace -->
            <div class="p-6 flex flex-col gap-6 overflow-hidden">
              <div class="flex items-center justify-between border-b border-border/40 pb-4">
                <div>
                  <h3 class="text-base font-bold text-fg">AI Review Queue</h3>
                  <p class="text-fg-subtle text-[11px]">3 tests parsed from <code class="bg-bg-elevated px-1 py-0.5 rounded text-primary text-[10px]">auth.spec.ts</code> via GitHub Commit <code>d2e9a1</code></p>
                </div>
                <button class="bg-primary hover:bg-primary-hover text-primary-fg text-xs font-semibold px-3 py-1.5 rounded-md shadow-sm transition-all">
                  Confirmar Todo
                </button>
              </div>

              <!-- Test Card 1 (AI Generated Case) -->
              <div class="rounded-lg border border-primary/20 bg-primary/5 p-4 flex flex-col gap-3 relative overflow-hidden group/card transition-all hover:border-primary/40">
                <div class="absolute top-0 right-0 bg-primary/10 text-primary text-[9px] font-bold px-2 py-0.5 rounded-bl">
                  NUEVO (AI-GENERATED)
                </div>
                <div class="flex items-center gap-2">
                  <span class="h-5 w-5 rounded bg-amber-500/20 text-amber-500 flex items-center justify-center font-bold text-[10px]">H</span>
                  <span class="font-bold text-fg">RF-01 · Iniciar sesión con GitHub OAuth</span>
                </div>
                <div class="grid grid-cols-[60px_1fr] text-[11px] gap-y-1 text-fg-muted">
                  <div class="text-fg-subtle">Pasos:</div>
                  <div>
                    1. Navegar a /login<br />
                    2. Hacer clic en "Iniciar sesión con GitHub"<br />
                    3. Autorizar la app en la ventana emergente
                  </div>
                  <div class="text-fg-subtle">Esperado:</div>
                  <div class="text-fg">Redirección exitosa a /dashboard con sesión activa y token de org inicializado</div>
                </div>
              </div>

              <!-- Test Card 2 (AI Generated Case 2) -->
              <div class="rounded-lg border border-border bg-bg-elevated/40 p-4 flex flex-col gap-3 opacity-60">
                <div class="flex items-center gap-2">
                  <span class="h-5 w-5 rounded bg-red-500/20 text-red-500 flex items-center justify-center font-bold text-[10px]">C</span>
                  <span class="font-bold text-fg">RF-02 · Lanzar test run manual</span>
                </div>
                <div class="grid grid-cols-[60px_1fr] text-[11px] gap-y-1 text-fg-muted">
                  <div class="text-fg-subtle">Pasos:</div>
                  <div>1. Ir a /projects/1/runs/new...</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Ambient light behind mockup -->
      <div class="absolute -inset-4 -z-10 rounded-xl bg-gradient-to-r from-primary/10 via-ai/10 to-primary/10 opacity-30 blur-2xl transition-all group-hover:opacity-50"></div>
    </div>
  </div>
</section>
